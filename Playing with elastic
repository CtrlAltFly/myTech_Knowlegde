JSR223 PostProcessor Script

def cartState = vars.get("cart_state")
def cartId = vars.get("cart_id")

if (cartState == "COMPLETED" || cartState == "MODIFIED") {
    def file = new File("/path/to/filtered_carts.csv")
    if (!file.exists()) {
        file.write("cart_id\n")
    }
    file.append("${cartId}\n")
}

Elasticsearch Export via API
Problem

Kibana has export limits (typically 10,000-150,000 rows). Need to export millions of records.
Solution: Direct Elasticsearch API with Scroll
Method 1: Bash Script with Curl (macOS Compatible)

#!/bin/bash

ES_URL="https://your-elasticsearch-host"
INDEX="your-index-name-*"
AUTH="username:password"
OUTPUT="export.csv"

echo "cart_id" > $OUTPUT

echo "Starting export..."

# Initial search with scroll
RESPONSE=$(curl -s -X POST "${ES_URL}/${INDEX}/_search?scroll=10m&size=10000" \
  -H 'Content-Type: application/json' \
  -u "$AUTH" \
  -d '{
    "query": {
        "bool": {
            "filter": [
                {
                    "range": {
                        "@timestamp": {
                            "gte": "2024-01-01T00:00:00.000Z",
                            "lte": "2024-12-31T23:59:59.999Z"
                        }
                    }
                },
                {
                    "match_phrase": {
                        "field.keyword": "VALUE"
                    }
                }
            ]
        }
    },
    "_source": ["field_to_extract"]
}')

# Extract data using Python JSON parsing
echo "$RESPONSE" | python3 -c "import sys, json; data=json.load(sys.stdin); [print(hit['_source']['field_to_extract']) for hit in data['hits']['hits']]" >> $OUTPUT

SCROLL_ID=$(echo "$RESPONSE" | python3 -c "import sys, json; print(json.load(sys.stdin)['_scroll_id'])")
HITS=$(echo "$RESPONSE" | python3 -c "import sys, json; print(len(json.load(sys.stdin)['hits']['hits']))")

COUNTER=$HITS
echo "First batch: $HITS records"

# Continue scrolling
while [ "$HITS" -gt 0 ]; do
    RESPONSE=$(curl -s -X POST "${ES_URL}/_search/scroll" \
      -H 'Content-Type: application/json' \
      -u "$AUTH" \
      -d "{\"scroll\": \"10m\", \"scroll_id\": \"$SCROLL_ID\"}")
    
    echo "$RESPONSE" | python3 -c "import sys, json; data=json.load(sys.stdin); [print(hit['_source']['field_to_extract']) for hit in data.get('hits', {}).get('hits', [])]" >> $OUTPUT
    
    SCROLL_ID=$(echo "$RESPONSE" | python3 -c "import sys, json; print(json.load(sys.stdin).get('_scroll_id', ''))")
    HITS=$(echo "$RESPONSE" | python3 -c "import sys, json; print(len(json.load(sys.stdin).get('hits', {}).get('hits', [])))")
    
    COUNTER=$((COUNTER + HITS))
    if [ $((COUNTER % 100000)) -lt 10000 ]; then
        echo "Progress: $COUNTER records..."
    fi
done

FINAL=$(($(wc -l < $OUTPUT) - 1))
echo "Export complete! Exported $FINAL records"

Method 2: Python Script (More Reliable)

from elasticsearch import Elasticsearch
from elasticsearch.helpers import scan
import csv

# Connect to Elasticsearch
es = Elasticsearch(
    ['https://your-elasticsearch-host'],
    basic_auth=('username', 'password'),
    timeout=60
)

# Define query
query = {
    "query": {
        "bool": {
            "filter": [
                {
                    "range": {
                        "@timestamp": {
                            "gte": "2024-01-01T00:00:00.000Z",
                            "lte": "2024-12-31T23:59:59.999Z"
                        }
                    }
                },
                {
                    "match_phrase": {
                        "field.keyword": "VALUE"
                    }
                }
            ]
        }
    },
    "_source": ["field1", "field2"]
}

print("Starting export...")

# Use scan helper - automatically handles scrolling
results = scan(
    es,
    query=query,
    index="your-index-name-*",
    size=10000,
    scroll='10m'
)

# Write to CSV
with open('export.csv', 'w', newline='') as f:
    writer = csv.writer(f)
    writer.writerow(['field1', 'field2'])
    
    count = 0
    for hit in results:
        source = hit['_source']
        writer.writerow([source.get('field1'), source.get('field2')])
        count += 1
        
        if count % 100000 == 0:
            print(f"Exported {count} records...")

print(f"Export complete! Total: {count} records")

